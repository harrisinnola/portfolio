---
/*
 * Custom 404 Page
 *
 * Astro automatically uses src/pages/404.astro when someone visits
 * a URL that doesn't match any page. The filename "404" is special.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="This page does not exist.">
  <h1>404</h1>
  <p>This page doesn't exist. <a href="/">Go home &rarr;</a></p>
</BaseLayout>
