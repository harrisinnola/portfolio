      "microbial innovation": `<ellipse cx="${c}" cy="${c*1.1}" rx="${c*0.5}" ry="${c*0.15}" fill="${col}" opacity="0.2"/><ellipse cx="${c}" cy="${c*0.9}" rx="${c*0.45}" ry="${c*0.12}" fill="${col}" opacity="0.15"/><ellipse cx="${c}" cy="${c*0.7}" rx="${c*0.35}" ry="${c*0.1}" fill="${col}" opacity="0.1"/>`,
      "planetary transition": `<circle cx="${c}" cy="${c}" r="${c*0.45}" fill="none" stroke="${col}" stroke-width="1.5" opacity="0.3"/><path d="M${c*0.3},${c} Q${c},${c*0.5} ${c*1.7},${c}" fill="none" stroke="${col}" stroke-width="1" opacity="0.4"/>`,
