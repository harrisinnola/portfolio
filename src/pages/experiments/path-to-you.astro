      "genus Homo": `<line x1="${c}" y1="${c*0.5}" x2="${c}" y2="${c*1.05}" stroke="${col}" stroke-width="2" opacity="0.35"/><circle cx="${c}" cy="${c*0.42}" r="${c*0.11}" fill="${col}" opacity="0.15" stroke="${col}" stroke-width="0.8" stroke-opacity="0.4"/><line x1="${c}" y1="${c*1.05}" x2="${c*0.82}" y2="${c*1.45}" stroke="${col}" stroke-width="2" opacity="0.3"/><line x1="${c}" y1="${c*1.05}" x2="${c*1.18}" y2="${c*1.45}" stroke="${col}" stroke-width="2" opacity="0.3"/><line x1="${c}" y1="${c*0.65}" x2="${c*0.65}" y2="${c*0.8}" stroke="${col}" stroke-width="1.5" opacity="0.3"/><line x1="${c}" y1="${c*0.65}" x2="${c*1.35}" y2="${c*0.8}" stroke="${col}" stroke-width="1.5" opacity="0.3"/>`,
      "modern-bodied hominin": `<line x1="${c}" y1="${c*0.45}" x2="${c}" y2="${c*1}" stroke="${col}" stroke-width="2.5" opacity="0.35"/><circle cx="${c}" cy="${c*0.37}" r="${c*0.12}" fill="${col}" opacity="0.15" stroke="${col}" stroke-width="1" stroke-opacity="0.4"/><line x1="${c}" y1="${c*1}" x2="${c*0.8}" y2="${c*1.5}" stroke="${col}" stroke-width="2.2" opacity="0.3"/><line x1="${c}" y1="${c*1}" x2="${c*1.2}" y2="${c*1.5}" stroke="${col}" stroke-width="2.2" opacity="0.3"/><line x1="${c}" y1="${c*0.6}" x2="${c*0.6}" y2="${c*0.78}" stroke="${col}" stroke-width="1.8" opacity="0.3"/><line x1="${c}" y1="${c*0.6}" x2="${c*1.4}" y2="${c*0.78}" stroke="${col}" stroke-width="1.8" opacity="0.3"/>`,
      "our species": `<line x1="${c}" y1="${c*0.42}" x2="${c}" y2="${c*0.98}" stroke="${col}" stroke-width="2.5" opacity="0.4"/><circle cx="${c}" cy="${c*0.33}" r="${c*0.13}" fill="${col}" opacity="0.18" stroke="${col}" stroke-width="1" stroke-opacity="0.5"/><line x1="${c}" y1="${c*0.98}" x2="${c*0.78}" y2="${c*1.5}" stroke="${col}" stroke-width="2.5" opacity="0.35"/><line x1="${c}" y1="${c*0.98}" x2="${c*1.22}" y2="${c*1.5}" stroke="${col}" stroke-width="2.5" opacity="0.35"/><line x1="${c}" y1="${c*0.58}" x2="${c*0.58}" y2="${c*0.75}" stroke="${col}" stroke-width="2" opacity="0.3"/><line x1="${c}" y1="${c*0.58}" x2="${c*1.42}" y2="${c*0.75}" stroke="${col}" stroke-width="2" opacity="0.3"/>`,
    };

    return shapes[wp.type] || shapes["environmental event"];
  }

  // ── SETUP ──────────────────────────────────────────────
  const scrollEl = document.getElementById('pty-scroll');
  const contentArea = document.getElementById('pty-content-area');
  const progressFill = document.getElementById('pty-progress-fill');
  const backEl = document.getElementById('pty-back');
  const ptyEl = document.getElementById('pty');
  const yearCounter = document.getElementById('pty-year-counter');
  const timelineCursor = document.getElementById('pty-timeline-cursor');
  const timelineBar = document.getElementById('pty-timeline-bar');

  // Compute scroll positions proportional to time gaps between waypoints
  // Using sqrt of gaps so billion-year gaps get lots of space but
  // million-year gaps are still scrollable (pure linear would crush them)
  const gaps = [];
  for (let i = 0; i < waypoints.length - 1; i++) {
    gaps.push(waypoints[i].years_ago - waypoints[i + 1].years_ago);
  }
  gaps.push(waypoints[waypoints.length - 1].years_ago); // last waypoint to present

  const sqrtGaps = gaps.map(g => Math.sqrt(g));
  const totalSqrtGaps = sqrtGaps.reduce((a, b) => a + b, 0);

  // wpScrollPos[i] = scroll progress (0..1) where waypoint i starts
  const wpScrollPos = [0];
  let cumulative = 0;
  for (let i = 0; i < sqrtGaps.length; i++) {
    cumulative += sqrtGaps[i] / totalSqrtGaps;
    wpScrollPos.push(cumulative);
  }

  // Total scroll height
  const totalHeight = SCALE * waypoints.length;
  const spacer = document.createElement('div');
  spacer.style.height = totalHeight + 'px';
  scrollEl.appendChild(spacer);

  // Build timeline markers at proportional positions
  const track = timelineBar.querySelector('.pty-timeline-track');
  waypoints.forEach((wp, i) => {
    const marker = document.createElement('div');
    marker.className = 'pty-timeline-marker';
    marker.style.top = (wpScrollPos[i] * 100) + '%';
    track.appendChild(marker);
  });

  const svgSize = 200;

  function formatYears(n) {
    if (n >= 1e9) return (n / 1e9).toFixed(1) + ' billion';
    if (n >= 1e6) return (n / 1e6).toFixed(1) + ' million';
    if (n >= 1e3) return n.toLocaleString();
    return String(Math.round(n));
  }

  // Pre-build all slides
  const slides = waypoints.map((wp) => {
    const slide = document.createElement('div');
    slide.className = 'pty-slide';

    const subjectEl = document.createElement('div');
    subjectEl.className = 'pty-subject';
    const shapes = makeSilhouette(wp, svgSize);
    subjectEl.innerHTML = `<svg viewBox="0 0 ${svgSize} ${svgSize}" xmlns="http://www.w3.org/2000/svg">${shapes}</svg>`;

    const textEl = document.createElement('div');
    textEl.className = 'pty-slide-text';
    textEl.innerHTML = `<h2 class="pty-slide-title">${wp.title}</h2><p class="pty-slide-sub">${wp.display_age} — ${wp.sub}</p>`;

    slide.appendChild(subjectEl);
    slide.appendChild(textEl);
    contentArea.appendChild(slide);
    return slide;
  });

  function lerp(a, b, t) {
    return a + (b - a) * t;
  }

  function update() {
    const scrollTop = scrollEl.scrollTop;
    const maxScroll = totalHeight - scrollEl.clientHeight;
    const progress = Math.min(Math.max(scrollTop / maxScroll, 0), 1);

    // Background: black to white
    const bg = Math.round(lerp(0, 255, progress));
    ptyEl.style.background = `rgb(${bg}, ${bg}, ${bg})`;

    // Text color
    const textBrightness = bg > 140 ? 0 : 255;
    const textColor = `rgb(${textBrightness}, ${textBrightness}, ${textBrightness})`;
    backEl.style.color = textColor;
    yearCounter.style.color = textColor;

    // Progress bar
    progressFill.style.width = (progress * 100) + '%';
    progressFill.style.background = bg > 140 ? 'rgba(0,0,0,0.3)' : 'rgba(255,255,255,0.3)';

    // Timeline cursor
    timelineCursor.style.top = (progress * 100) + '%';
    timelineCursor.style.background = textColor;

    // Find which waypoint section we're in
    let waypointIndex = 0;
    for (let i = waypoints.length - 1; i >= 0; i--) {
      if (progress >= wpScrollPos[i]) {
        waypointIndex = i;
        break;
      }
    }

    // How far through the current section (0..1)
    const sectionStart = wpScrollPos[waypointIndex];
    const sectionEnd = wpScrollPos[waypointIndex + 1];
    const sectionFrac = sectionEnd > sectionStart
      ? (progress - sectionStart) / (sectionEnd - sectionStart)
      : 0;

    // Year counter
    const currentYears = waypoints[waypointIndex].years_ago;
    const nextYears = waypointIndex < waypoints.length - 1
      ? waypoints[waypointIndex + 1].years_ago
      : 0;
    const interpolatedYears = lerp(currentYears, nextYears, sectionFrac);
    const displayYears = Math.max(0, Math.round(interpolatedYears));

    if (displayYears <= 0) {
      yearCounter.textContent = 'Now';
    } else {
      yearCounter.textContent = formatYears(displayYears) + ' years ago';
    }

    // Position each slide based on scroll
    // Slides stay at center (0) until the NEXT slide scrolls in from below to push it out
    const viewH = window.innerHeight;
    for (let i = 0; i < slides.length; i++) {
      const slideStart = wpScrollPos[i];
      const nextStart = wpScrollPos[i + 1] !== undefined ? wpScrollPos[i + 1] : 1;

      let yOffset;
      if (progress < slideStart) {
        // Haven't reached this slide — fully below
        yOffset = viewH;
      } else if (i < slides.length - 1 && progress >= nextStart) {
        // Next slide has arrived — this one is pushed fully above
        yOffset = -viewH;
      } else if (progress >= slideStart && progress < nextStart) {
        // Active section — slide sits at 0
        // But as we approach the next section boundary, the NEXT slide
        // is scrolling in from below, so this one stays put
        yOffset = 0;
      } else {
        yOffset = -viewH;
      }

      slides[i].style.transform = `translateY(${yOffset}px)`;

      // The incoming next slide should scroll proportionally from below
      if (i > 0) {
        const prevEnd = wpScrollPos[i]; // when this slide's section starts
        const prevStart = wpScrollPos[i - 1];
        // During the previous section, this slide scrolls in from below
        if (progress >= prevStart && progress < prevEnd) {
          const frac = (progress - prevStart) / (prevEnd - prevStart);
          // Slide in from bottom: starts at viewH, ends at 0
          yOffset = viewH * (1 - frac);
          slides[i].style.transform = `translateY(${yOffset}px)`;
        }
      }

      // Set text color on each slide
      const title = slides[i].querySelector('.pty-slide-title');
      const sub = slides[i].querySelector('.pty-slide-sub');
      if (title) title.style.color = textColor;
      if (sub) sub.style.color = textColor;
    }
  }

  scrollEl.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', update);
  update();
</script>
