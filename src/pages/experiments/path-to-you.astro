---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Path To You" description="A scroll-driven journey through time, from darkness to light.">
  <div class="pty" id="pty">
    <div class="pty-scroll" id="pty-scroll"></div>

    <div class="pty-fixed" id="pty-fixed">
      <div class="pty-content-area" id="pty-content-area"></div>
      <div class="pty-progress-bar">
        <div class="pty-progress-fill" id="pty-progress-fill"></div>
      </div>
    </div>

    <div class="pty-year-counter" id="pty-year-counter">4,100,000,000 years ago</div>

    <div class="pty-timeline-bar" id="pty-timeline-bar">
      <div class="pty-timeline-track">
        <div class="pty-timeline-line"></div>
        <div class="pty-timeline-cursor" id="pty-timeline-cursor"></div>
      </div>
    </div>

    <a href="/experiments/" class="pty-back" id="pty-back">&larr; Back</a>
  </div>
</BaseLayout>

<style is:global>
  .pty {
    position: fixed;
    inset: 0;
    overflow: hidden;
    font-family: var(--font-body);
  }

  .pty-scroll {
    position: absolute;
    inset: 0;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .pty-fixed {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
  }

  .pty-content-area {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .pty-slide {
    position: absolute;
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    will-change: transform;
  }

  .pty-subject {
    width: 300px;
    height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .pty-subject svg {
    width: 100%;
    height: 100%;
  }

  .pty-slide-text {
    text-align: center;
    max-width: 500px;
    padding: 0 2rem;
  }

  .pty-slide-title {
    font-size: 2rem;
    font-weight: 200;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }

  .pty-slide-sub {
    font-size: 1rem;
    font-weight: 200;
    line-height: 1.6;
    margin: 0;
  }

  .pty-progress-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: rgba(128, 128, 128, 0.2);
    z-index: 10;
  }

  .pty-progress-fill {
    height: 100%;
    width: 0%;
    transition: background 0.3s ease;
  }

  .pty-back {
    position: fixed;
    top: 1rem;
    left: 1.5rem;
    z-index: 20;
    font-size: 0.8125rem;
    text-decoration: none;
    transition: color 0.3s, opacity 0.3s;
  }

  .pty-year-counter {
    position: fixed;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 2.5rem;
    font-weight: 200;
    letter-spacing: 0.04em;
    z-index: 10;
    transition: color 0.3s ease;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .pty-timeline-bar {
    position: fixed;
    left: 1rem;
    top: 3.5rem;
    bottom: 3rem;
    width: 9px;
    z-index: 10;
    pointer-events: none;
  }

  .pty-timeline-track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .pty-timeline-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(128, 128, 128, 0.2);
    border-radius: 2px;
  }

  .pty-timeline-marker {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: #c8a800;
    pointer-events: none;
  }

  .pty-timeline-cursor {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #fff;
    transition: top 0.15s ease, background 0.3s ease;
    pointer-events: none;
  }

  @media (max-width: 640px) {
    .pty-slide-title { font-size: 1.5rem; }
    .pty-slide-sub { font-size: 0.875rem; }
    .pty-subject { width: 200px; height: 200px; }
    .pty-timeline-bar { left: 0.5rem; }
    .pty-year-counter { font-size: 1.5rem; top: 1rem; }
  }
</style>

<script>
  // ── CONFIG ──────────────────────────────────────────────
  // Scale: pixels of scroll per timeline section. Increase for slower scroll.
  const SCALE = 2000;

  const waypoints = [
    { title:"Alkaline hydrothermal vents", sub:"A leading origin-of-life hypothesis places prebiotic chemistry in porous alkaline vent systems that supplied chemical gradients, mineral surfaces, and compartment-like spaces.", display_age:"ca. 4.1 billion years ago", years_ago:4100000000, type:"environmental event", palette:["#1a0800","#3d1800","#6b3a1a"] },
    { title:"Protocell-like compartments", sub:"Before true cells, chemistry may have been concentrated inside mineral pores or primitive membrane compartments that stabilized reactions.", display_age:"ca. 4.0 billion years ago", years_ago:4000000000, type:"precellular transition", palette:["#0d0a1a","#1a1233","#2a1f4d"] },
    { title:"First cells / LUCA-grade microbe", sub:"The last universal common ancestor marks the point after which all known life shares a common biological inheritance.", display_age:"older than 3.9 billion years ago", years_ago:3900000000, type:"microbial ancestor", palette:["#0a0f1a","#0f1a2d","#1a2d47"] },
    { title:"Cyanobacterial mats", sub:"Oxygenic photosynthesis by cyanobacteria helped transform Earth's atmosphere and oceans.", display_age:"ca. 2.7 billion years ago", years_ago:2700000000, type:"microbial innovation", palette:["#0a1a0f","#0f2d1a","#1a4729"] },
    { title:"Great Oxidation Event", sub:"Atmospheric oxygen rose for the first time at planetary scale, opening ecological space for new metabolisms and later complexity.", display_age:"2.4 to 2.2 billion years ago", years_ago:2400000000, type:"planetary transition", palette:["#0a1520","#0f2540","#1a3d5c"] },
    { title:"First eukaryotes", sub:"Eukaryotic cells introduced internal compartmentalization and, eventually, the lineage that led to animals, plants, and fungi.", display_age:"ca. 1.8 billion years ago", years_ago:1800000000, type:"cellular transition", palette:["#1a0d1a","#2d1a2d","#472a47"] },
    { title:"Complex multicellular eukaryotes", sub:"Large multicellular bodies and cellular differentiation emerged long before animals appeared.", display_age:"ca. 1.0 billion years ago", years_ago:1000000000, type:"multicellularity transition", palette:["#0a1a12","#0f2d1f","#1a4730"] },
    { title:"Ediacaran animals", sub:"The Ediacaran world preserves the earliest large, complex organisms and the first clear rise of animal-grade ecosystems.", display_age:"ca. 575 million years ago", years_ago:575000000, type:"early animals", palette:["#0f0d1a","#1a1533","#2d2355"] },
    { title:"Bilaterian animals", sub:"Bilaterian body plans set up the left-right symmetry, front-back axes, and organ systems behind most later animals, including us.", display_age:"ca. 550 million years ago", years_ago:550000000, type:"body-plan transition", palette:["#12100d","#24201a","#3d3528"] },
    { title:"Jawless vertebrates", sub:"Early vertebrates established the basic vertebrate body plan: head, braincase, backbone, and sensory systems.", display_age:"about 500 million years ago", years_ago:500000000, type:"vertebrate origin", palette:["#0d1218","#1a2530","#283d50"] },
    { title:"Jawed fishes", sub:"Jaws transformed feeding and predation, and jawed vertebrates became the ancestors of bony fishes, sharks, and eventually tetrapods.", display_age:"ca. 420 million years ago", years_ago:420000000, type:"vertebrate innovation", palette:["#0d1515","#1a2d2d","#284747"] },
    { title:"Lobe-finned fishes", sub:"Our lineage runs through lobe-finned fishes, whose robust fins provided the anatomical basis for later limbs.", display_age:"ca. 390 million years ago", years_ago:390000000, type:"tetrapod stem", palette:["#0f1510","#1a2d1f","#284730"] },
    { title:"Stem tetrapods", sub:"Stem tetrapods combined fish and tetrapod traits, including stronger girdles, mobile neck regions, and limb-like fins.", display_age:"ca. 375 million years ago", years_ago:375000000, type:"water-to-land transition", palette:["#15120d","#2d251a","#473d28"] },
    { title:"Early tetrapods", sub:"Limbed vertebrates became capable of moving through shallow water and onto land, starting the terrestrial vertebrate story.", display_age:"ca. 365 million years ago", years_ago:365000000, type:"land-capable vertebrate", palette:["#12150d","#252d1a","#3d4728"] },
    { title:"Amniotes", sub:"Amniotes reproduced away from open water using protected eggs and associated membranes, freeing vertebrates from aquatic breeding.", display_age:"ca. 320 million years ago", years_ago:320000000, type:"reproductive transition", palette:["#150f0d","#2d1f1a","#473228"] },
    { title:"Synapsids", sub:"Synapsids are the amniote branch that ultimately gave rise to mammals, including humans.", display_age:"ca. 300 million years ago", years_ago:300000000, type:"mammal-line ancestor", palette:["#1a0f0a","#331f15","#4d3020"] },
    { title:"Cynodonts", sub:"Cynodonts show many mammal-leaning traits, including differentiated teeth and jaw-ear transitions on the path toward true mammals.", display_age:"ca. 240 million years ago", years_ago:240000000, type:"mammalian transition", palette:["#15100d","#2d221a","#473828"] },
    { title:"Early mammals", sub:"The earliest mammals were small but they established the body plan and physiology that would eventually produce primates and humans.", display_age:"225 to 205 million years ago", years_ago:225000000, type:"true mammals", palette:["#0d1015","#1a222d","#283847"] },
    { title:"Early primates", sub:"Early primates adapted to arboreal life with grasping hands, flexible shoulders, and visual specialization that set the stage for apes and humans.", display_age:"56 to 65 million years ago", years_ago:56000000, type:"primate origin", palette:["#0d150f","#1a2d20","#284733"] },
    { title:"Early apes", sub:"Miocene apes represent the branch from which African apes and, much later, humans emerged.", display_age:"ca. 18 million years ago", years_ago:18000000, type:"ape lineage", palette:["#12150d","#252d1a","#3d4728"] },
    { title:"Earliest hominins", sub:"This marks the human lineage after the split from the lineage leading to chimpanzees and bonobos.", display_age:"7 to 6 million years ago", years_ago:6500000, type:"human-line split", palette:["#15120a","#2d2515","#4d3d22"] },
    { title:"Australopithecus afarensis", sub:"A. afarensis combined habitual bipedalism with retained climbing traits and is one of the clearest early human waypoints.", display_age:"3.85 to 2.95 million years ago", years_ago:3400000, type:"bipedal hominin", palette:["#1a150d","#332a1a","#4d4028"] },
    { title:"Homo habilis", sub:"Early Homo shows a larger braincase and a more human-like face than australopiths and is closely associated with early stone tool use.", display_age:"2.4 to 1.4 million years ago", years_ago:2000000, type:"genus Homo", palette:["#15100a","#2d2215","#4d3822"] },
    { title:"Homo erectus", sub:"H. erectus had more modern body proportions, traveled beyond Africa, and represents a major shift toward the human body plan.", display_age:"1.89 Ma to 110 ka", years_ago:1600000, type:"modern-bodied hominin", palette:["#120d0a","#251a15","#3d2d22"] },
    { title:"Homo sapiens", sub:"Our species emerged in Africa roughly 300,000 years ago and later spread worldwide, carrying cumulative culture, language, art, and technology.", display_age:"at least 300,000 years ago to present", years_ago:300000, type:"our species", palette:["#0f0f15","#1a1a2d","#2d2d47"] },
  ];

  // ── SVG SILHOUETTES (from Lineage) ─────────────────────
  function makeSilhouette(wp, size) {
    const s = size;
    const c = s / 2;
    const col = wp.palette[2];

    const shapes = {
      "environmental event": `<circle cx="${c}" cy="${c}" r="${c*0.4}" fill="none" stroke="${col}" stroke-width="1.5" opacity="0.6"/><circle cx="${c}" cy="${c*0.7}" r="${c*0.15}" fill="${col}" opacity="0.3"/><line x1="${c}" y1="${c*0.3}" x2="${c}" y2="${c*1.5}" stroke="${col}" stroke-width="1" opacity="0.4"/><line x1="${c*0.7}" y1="${c*0.5}" x2="${c*0.7}" y2="${c*1.6}" stroke="${col}" stroke-width="0.8" opacity="0.3"/><line x1="${c*1.3}" y1="${c*0.4}" x2="${c*1.3}" y2="${c*1.4}" stroke="${col}" stroke-width="0.8" opacity="0.3"/>`,
