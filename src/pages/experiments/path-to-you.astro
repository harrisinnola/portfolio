---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Path To You" description="A scroll-driven journey through time, from darkness to light.">
  <div class="pty" id="pty">
    <div class="pty-scroll" id="pty-scroll"></div>

    <div class="pty-fixed" id="pty-fixed">
      <div class="pty-content-area" id="pty-content-area"></div>
      <div class="pty-progress-bar">
        <div class="pty-progress-fill" id="pty-progress-fill"></div>
      </div>
    </div>

    <div class="pty-year-counter" id="pty-year-counter">4,100,000,000 years ago</div>

    <div class="pty-timeline-bar" id="pty-timeline-bar">
      <div class="pty-timeline-track">
        <div class="pty-timeline-line"></div>
        <div class="pty-timeline-cursor" id="pty-timeline-cursor"></div>
      </div>
    </div>

    <a href="/experiments/" class="pty-back" id="pty-back">&larr; Back</a>
  </div>
</BaseLayout>

<style is:global>
  .pty {
    position: fixed;
    inset: 0;
    overflow: hidden;
    font-family: var(--font-body);
  }

  .pty-scroll {
    position: absolute;
    inset: 0;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .pty-fixed {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
  }

  .pty-content-area {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .pty-slide {
    position: absolute;
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
  }

  .pty-subject {
    width: 400px;
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: -1rem;
    will-change: opacity;
  }

  .pty-subject img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .pty-slide-text {
    text-align: center;
    max-width: 500px;
    padding: 0 2rem;
  }

  .pty-slide-title {
    font-size: 2rem;
    font-weight: 200;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }

  .pty-slide-sub {
    font-size: 1rem;
    font-weight: 200;
    line-height: 1.6;
    margin: 0;
    will-change: opacity;
  }

  .pty-progress-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: rgba(128, 128, 128, 0.2);
    z-index: 10;
  }

  .pty-progress-fill {
    height: 100%;
    width: 0%;
    transition: background 0.3s ease;
  }

  .pty-back {
    position: fixed;
    top: 1rem;
    left: 1.5rem;
    z-index: 20;
    font-size: 0.8125rem;
    text-decoration: none;
    transition: color 0.3s, opacity 0.3s;
  }

  .pty-year-counter {
    position: fixed;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 2.5rem;
    font-weight: 200;
    letter-spacing: 0.04em;
    z-index: 10;
    transition: color 0.3s ease;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .pty-timeline-bar {
    position: fixed;
    left: 1rem;
    top: 3.5rem;
    bottom: 3rem;
    width: 18px;
    z-index: 10;
    pointer-events: none;
  }

  .pty-timeline-track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .pty-timeline-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(128, 128, 128, 0.2);
    border-radius: 2px;
  }

  .pty-timeline-marker {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: #c8a800;
    pointer-events: none;
  }

  .pty-timeline-cursor {
    position: absolute;
    left: 0;
    width: 100%;
    height: 6px;
    border-radius: 1px;
    background: #fff;
    transition: top 0.15s ease, background 0.3s ease;
    pointer-events: none;
  }

  @media (max-width: 640px) {
    .pty-slide-title { font-size: 1.5rem; }
    .pty-slide-sub { font-size: 0.875rem; }
    .pty-subject { width: 400px; height: 400px; }
    .pty-timeline-bar { left: 0.5rem; }
    .pty-year-counter { font-size: 1.5rem; top: 1rem; }
  }
</style>

<script>
  // ── CONFIG ──────────────────────────────────────────────
  // Scale: pixels of scroll per timeline section. Increase for slower scroll.
  const SCALE = 4000;

  const waypoints = [
    { title:"Alkaline hydrothermal vents", sub:"A leading origin-of-life hypothesis places prebiotic chemistry in porous alkaline vent systems that supplied chemical gradients, mineral surfaces, and compartment-like spaces.", display_age:"~4.1 billion years ago", years_ago:4100000000, img:"/images/path-to-you/01-vents.png" },
    { title:"Protocell-like compartments", sub:"Before true cells, chemistry may have been concentrated inside mineral pores or primitive membrane compartments that stabilized reactions.", display_age:"~4.0 billion years ago", years_ago:4000000000, img:"/images/path-to-you/02-protocells.png" },
    { title:"First cells / LUCA-grade microbe", sub:"The last universal common ancestor marks the point after which all known life shares a common biological inheritance.", display_age:"older than 3.9 billion years ago", years_ago:3900000000, img:"/images/path-to-you/03-first-cells.png" },
    { title:"Cyanobacterial mats", sub:"Oxygenic photosynthesis by cyanobacteria helped transform Earth's atmosphere and oceans.", display_age:"~2.7 billion years ago", years_ago:2700000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Great Oxidation Event", sub:"Atmospheric oxygen rose for the first time at planetary scale, opening ecological space for new metabolisms and later complexity.", display_age:"2.4 to 2.2 billion years ago", years_ago:2400000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"First eukaryotes", sub:"Eukaryotic cells introduced internal compartmentalization and, eventually, the lineage that led to animals, plants, and fungi.", display_age:"~1.8 billion years ago", years_ago:1800000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Complex multicellular eukaryotes", sub:"Large multicellular bodies and cellular differentiation emerged long before animals appeared.", display_age:"~1.0 billion years ago", years_ago:1000000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Ediacaran animals", sub:"The Ediacaran world preserves the earliest large, complex organisms and the first clear rise of animal-grade ecosystems.", display_age:"~575 million years ago", years_ago:575000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Bilaterian animals", sub:"Bilaterian body plans set up the left-right symmetry, front-back axes, and organ systems behind most later animals, including us.", display_age:"~550 million years ago", years_ago:550000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Jawless vertebrates", sub:"Early vertebrates established the basic vertebrate body plan: head, braincase, backbone, and sensory systems.", display_age:"about 500 million years ago", years_ago:500000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Jawed fishes", sub:"Jaws transformed feeding and predation, and jawed vertebrates became the ancestors of bony fishes, sharks, and eventually tetrapods.", display_age:"~420 million years ago", years_ago:420000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Lobe-finned fishes", sub:"Our lineage runs through lobe-finned fishes, whose robust fins provided the anatomical basis for later limbs.", display_age:"~390 million years ago", years_ago:390000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Stem tetrapods", sub:"Stem tetrapods combined fish and tetrapod traits, including stronger girdles, mobile neck regions, and limb-like fins.", display_age:"~375 million years ago", years_ago:375000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Early tetrapods", sub:"Limbed vertebrates became capable of moving through shallow water and onto land, starting the terrestrial vertebrate story.", display_age:"~365 million years ago", years_ago:365000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Amniotes", sub:"Amniotes reproduced away from open water using protected eggs and associated membranes, freeing vertebrates from aquatic breeding.", display_age:"~320 million years ago", years_ago:320000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Synapsids", sub:"Synapsids are the amniote branch that ultimately gave rise to mammals, including humans.", display_age:"~300 million years ago", years_ago:300000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Cynodonts", sub:"Cynodonts show many mammal-leaning traits, including differentiated teeth and jaw-ear transitions on the path toward true mammals.", display_age:"~240 million years ago", years_ago:240000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Early mammals", sub:"The earliest mammals were small but they established the body plan and physiology that would eventually produce primates and humans.", display_age:"225 to 205 million years ago", years_ago:225000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Early primates", sub:"Early primates adapted to arboreal life with grasping hands, flexible shoulders, and visual specialization that set the stage for apes and humans.", display_age:"56 to 65 million years ago", years_ago:56000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Early apes", sub:"Miocene apes represent the branch from which African apes and, much later, humans emerged.", display_age:"~18 million years ago", years_ago:18000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Earliest hominins", sub:"This marks the human lineage after the split from the lineage leading to chimpanzees and bonobos.", display_age:"7 to 6 million years ago", years_ago:6500000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Australopithecus afarensis", sub:"A. afarensis combined habitual bipedalism with retained climbing traits and is one of the clearest early human waypoints.", display_age:"3.85 to 2.95 million years ago", years_ago:3400000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Homo habilis", sub:"Early Homo shows a larger braincase and a more human-like face than australopiths and is closely associated with early stone tool use.", display_age:"2.4 to 1.4 million years ago", years_ago:2000000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Homo erectus", sub:"H. erectus had more modern body proportions, traveled beyond Africa, and represents a major shift toward the human body plan.", display_age:"1.89 Ma to 110 ka", years_ago:1600000, img:"/images/path-to-you/04-cyanobacteria.png" },
    { title:"Homo sapiens", sub:"Our species emerged in Africa roughly 300,000 years ago and later spread worldwide, carrying cumulative culture, language, art, and technology.", display_age:"at least 300,000 years ago to present", years_ago:300000, img:"/images/path-to-you/04-cyanobacteria.png" },
  ];

  // ── SETUP ──────────────────────────────────────────────
  const scrollEl = document.getElementById('pty-scroll');
  const contentArea = document.getElementById('pty-content-area');
  const progressFill = document.getElementById('pty-progress-fill');
  const backEl = document.getElementById('pty-back');
  const ptyEl = document.getElementById('pty');
  const yearCounter = document.getElementById('pty-year-counter');
  const timelineCursor = document.getElementById('pty-timeline-cursor');
  const timelineBar = document.getElementById('pty-timeline-bar');

  // Compute scroll positions proportional to time gaps between waypoints
  // Using sqrt of gaps so billion-year gaps get lots of space but
  // million-year gaps are still scrollable (pure linear would crush them)
  const gaps = [];
  for (let i = 0; i < waypoints.length - 1; i++) {
    gaps.push(waypoints[i].years_ago - waypoints[i + 1].years_ago);
  }
  gaps.push(waypoints[waypoints.length - 1].years_ago); // last waypoint to present

  const sqrtGaps = gaps.map(g => Math.sqrt(g));
  const totalSqrtGaps = sqrtGaps.reduce((a, b) => a + b, 0);

  // wpScrollPos[i] = scroll progress (0..1) where waypoint i starts
  const wpScrollPos = [0];
  let cumulative = 0;
  for (let i = 0; i < sqrtGaps.length; i++) {
    cumulative += sqrtGaps[i] / totalSqrtGaps;
    wpScrollPos.push(cumulative);
  }

  // Total scroll height
  const totalHeight = SCALE * waypoints.length;
  const spacer = document.createElement('div');
  spacer.style.height = totalHeight + 'px';
  scrollEl.appendChild(spacer);

  // Build timeline markers at proportional positions
  const track = timelineBar.querySelector('.pty-timeline-track');
  waypoints.forEach((wp, i) => {
    const marker = document.createElement('div');
    marker.className = 'pty-timeline-marker';
    marker.style.top = (wpScrollPos[i] * 100) + '%';
    track.appendChild(marker);
  });

  function formatYears(n) {
    if (n >= 1e9) return (n / 1e9).toFixed(1) + ' billion';
    if (n >= 1e6) return (n / 1e6).toFixed(1) + ' million';
    if (n >= 1e3) return n.toLocaleString();
    return String(Math.round(n));
  }

  // Pre-build all slides
  const slides = waypoints.map((wp) => {
    const slide = document.createElement('div');
    slide.className = 'pty-slide';

    const subjectEl = document.createElement('div');
    subjectEl.className = 'pty-subject';
    subjectEl.innerHTML = `<img src="${wp.img}" alt="" />`;

    const textEl = document.createElement('div');
    textEl.className = 'pty-slide-text';
    textEl.innerHTML = `<h2 class="pty-slide-title">${wp.title}</h2><p class="pty-slide-sub">${wp.display_age} — ${wp.sub}</p>`;

    slide.appendChild(subjectEl);
    slide.appendChild(textEl);
    contentArea.appendChild(slide);
    return slide;
  });

  function lerp(a, b, t) {
    return a + (b - a) * t;
  }

  function update() {
    const scrollTop = scrollEl.scrollTop;
    const maxScroll = totalHeight - scrollEl.clientHeight;
    const progress = Math.min(Math.max(scrollTop / maxScroll, 0), 1);

    // Background: black to white
    const bg = Math.round(lerp(0, 255, progress));
    ptyEl.style.background = `rgb(${bg}, ${bg}, ${bg})`;

    // Text color
    const textBrightness = bg > 140 ? 0 : 255;
    const textColor = `rgb(${textBrightness}, ${textBrightness}, ${textBrightness})`;
    backEl.style.color = textColor;
    yearCounter.style.color = textColor;

    // Progress bar
    progressFill.style.width = (progress * 100) + '%';
    progressFill.style.background = bg > 140 ? 'rgba(0,0,0,0.3)' : 'rgba(255,255,255,0.3)';

    // Timeline cursor
    timelineCursor.style.top = (progress * 100) + '%';
    timelineCursor.style.background = textColor;

    // Find which waypoint section we're in
    let waypointIndex = 0;
    for (let i = waypoints.length - 1; i >= 0; i--) {
      if (progress >= wpScrollPos[i]) {
        waypointIndex = i;
        break;
      }
    }

    // How far through the current section (0..1)
    const sectionStart = wpScrollPos[waypointIndex];
    const sectionEnd = wpScrollPos[waypointIndex + 1];
    const sectionFrac = sectionEnd > sectionStart
      ? (progress - sectionStart) / (sectionEnd - sectionStart)
      : 0;

    // Year counter
    const currentYears = waypoints[waypointIndex].years_ago;
    const nextYears = waypointIndex < waypoints.length - 1
      ? waypoints[waypointIndex + 1].years_ago
      : 0;
    const interpolatedYears = lerp(currentYears, nextYears, sectionFrac);
    const displayYears = Math.max(0, Math.round(interpolatedYears));

    if (displayYears <= 0) {
      yearCounter.textContent = 'Now';
    } else {
      yearCounter.textContent = formatYears(displayYears) + ' years ago';
    }

    // Determine which slide is active based on scroll progress
    for (let i = 0; i < slides.length; i++) {
      const slideStart = wpScrollPos[i];
      const slideEnd = wpScrollPos[i + 1] !== undefined ? wpScrollPos[i + 1] : 1;

      const isActive = progress >= slideStart && progress < slideEnd;
      const isLast = i === slides.length - 1 && progress >= slideStart;
      const visible = isActive || isLast;

      // Image: fade in/out
      const subjectEl = slides[i].querySelector('.pty-subject');
      if (subjectEl) {
        subjectEl.style.transition = 'opacity 1s ease-in-out';
        subjectEl.style.opacity = visible ? 1 : 0;
      }

      // Title: fade in/out with slight vertical movement
      const title = slides[i].querySelector('.pty-slide-title');
      if (title) {
        title.style.transition = 'opacity 1s ease-in-out 0.3s, transform 1s ease-in-out 0.3s';
        title.style.opacity = visible ? 1 : 0;
        title.style.transform = visible ? 'translateY(0)' : 'translateY(12px)';
        title.style.color = textColor;
      }

      // Sub text: fade in/out with slight vertical movement, staggered
      const sub = slides[i].querySelector('.pty-slide-sub');
      if (sub) {
        sub.style.transition = 'opacity 1s ease-in-out 0.6s, transform 1s ease-in-out 0.6s';
        sub.style.opacity = visible ? 1 : 0;
        sub.style.transform = visible ? 'translateY(0)' : 'translateY(12px)';
        sub.style.color = textColor;
      }

      // Show/hide the slide itself
      slides[i].style.display = visible ? 'flex' : 'none';
    }
  }

  scrollEl.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', update);
  update();
</script>
