---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimeHeader from '../../components/TimeHeader.astro';
import ExperimentCard from '../../components/ExperimentCard.astro';

const experiments = [
  {
    title: 'Path To You',
    description: 'A scroll-driven journey through time, from darkness to light.',
    href: '/experiments/path-to-you/',
    status: 'new',
  },
];
---

<BaseLayout title="Ideas" description="Interactive ideas and creative coding by Mike Harris.">
  <TimeHeader size={120} />

  <h1>Ideas</h1>
  <p class="page-description">Web based interactive experiences.</p>

  <div class="experiment-grid">
    {experiments.map(experiment => (
      <ExperimentCard
        title={experiment.title}
        description={experiment.description}
        href={experiment.href}
        status={experiment.status}
      />
    ))}
  </div>
</BaseLayout>

<style>
  .page-description {
    color: var(--color-muted);
    margin-bottom: var(--space-lg);
  }

  .experiment-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-md);
  }
</style>
