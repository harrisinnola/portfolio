---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Centeric" description="See the planets and moon in your sky, right now.">
  <div class="ce" id="ce">
    <canvas id="ce-canvas"></canvas>
    <canvas id="ce-overlay"></canvas>

    <div class="ce-location-bar" id="ce-location-bar">
      <form id="ce-form">
        <input
          type="text"
          id="ce-input"
          placeholder="Enter location"
          autocomplete="off"
          spellcheck="false"
        />
        <button type="submit" id="ce-go">Go</button>
      </form>
      <p class="ce-status" id="ce-status"></p>
    </div>

    <div class="ce-info" id="ce-info">
      <span id="ce-direction"></span>
    </div>

    <div class="ce-toggles" id="ce-toggles">
      <button class="ce-toggle-btn" id="ce-toggle-btn" type="button" aria-label="Toggle body visibility">Filter</button>
      <div class="ce-toggle-panel hidden" id="ce-toggle-panel"></div>
    </div>

    <a href="/experiments/" class="ce-back">&larr; Back</a>
  </div>
</BaseLayout>

<style is:global>
  .ce {
    position: fixed;
    inset: 0;
    overflow: hidden;
    background: #000;
    font-family: var(--font-body);
    cursor: grab;
    touch-action: none;
  }

  .ce:active {
    cursor: grabbing;
  }

  #ce-canvas, #ce-overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #ce-overlay {
    pointer-events: none;
    z-index: 1;
  }

  .ce-location-bar {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    text-align: center;
  }

  #ce-form {
    display: flex;
    gap: 0.5rem;
  }

  #ce-input {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 200;
    letter-spacing: 0.02em;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 2rem;
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    width: 260px;
    outline: none;
    transition: border-color 0.2s;
  }

  #ce-input::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  #ce-input:focus {
    border-color: rgba(255, 255, 255, 0.5);
  }

  #ce-go {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 200;
    letter-spacing: 0.04em;
    padding: 0.5rem 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 2rem;
    background: transparent;
    color: #fff;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }

  #ce-go:hover {
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.05);
  }

  .ce-status {
    font-size: 0.75rem;
    font-weight: 200;
    color: rgba(255, 255, 255, 0.4);
    margin-top: 0.4rem;
    margin-bottom: 0;
  }

  .ce-info {
    position: fixed;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    pointer-events: none;
    text-align: center;
  }

  #ce-direction {
    font-size: 0.875rem;
    font-weight: 200;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
  }

  .ce-back {
    position: fixed;
    top: 1rem;
    left: 1.5rem;
    z-index: 25;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.2s;
  }

  .ce-back:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  .ce-toggles {
    position: fixed;
    top: 1rem;
    right: 1.5rem;
    z-index: 25;
  }

  .ce-toggle-btn {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 200;
    letter-spacing: 0.04em;
    padding: 0.35rem 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 1rem;
    background: rgba(0, 0, 0, 0.5);
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }

  .ce-toggle-btn:hover {
    border-color: rgba(255, 255, 255, 0.4);
    background: rgba(0, 0, 0, 0.7);
  }

  .ce-toggle-panel {
    margin-top: 0.4rem;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.5rem;
    padding: 0.4rem 0;
    min-width: 150px;
    overflow: hidden;
    transform-origin: top right;
    transition: opacity 0.2s ease, transform 0.2s ease;
    opacity: 1;
    transform: scaleY(1);
  }

  .ce-toggle-panel.hidden {
    opacity: 0;
    transform: scaleY(0);
    pointer-events: none;
  }

  .ce-toggle-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    cursor: pointer;
    transition: background 0.15s;
  }

  .ce-toggle-row:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  .ce-toggle-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .ce-toggle-row label {
    font-size: 0.75rem;
    font-weight: 200;
    cursor: pointer;
    flex: 1;
  }

  .ce-toggle-row input[type="checkbox"] {
    appearance: none;
    width: 12px;
    height: 12px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 2px;
    background: transparent;
    cursor: pointer;
    position: relative;
    flex-shrink: 0;
  }

  .ce-toggle-row input[type="checkbox"]:checked {
    background: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 640px) {
    #ce-input { width: 180px; font-size: 0.8125rem; }
    #ce-go { padding: 0.5rem 0.8rem; font-size: 0.8125rem; }
    .ce-location-bar { bottom: 1rem; }
    .ce-toggles { right: 0.75rem; }
  }
</style>

<script>
  import * as Astronomy from 'astronomy-engine';

  // ── ELEMENTS ─────────────────────────────────────────
  const glCanvas = document.getElementById('ce-canvas') as HTMLCanvasElement;
  const overlay = document.getElementById('ce-overlay') as HTMLCanvasElement;
  const ctx = overlay.getContext('2d')!;
  const form = document.getElementById('ce-form') as HTMLFormElement;
  const input = document.getElementById('ce-input') as HTMLInputElement;
  const statusEl = document.getElementById('ce-status')!;
  const directionEl = document.getElementById('ce-direction')!;
  const toggleBtn = document.getElementById('ce-toggle-btn')!;
  const togglePanel = document.getElementById('ce-toggle-panel')!;

  // ── WEBGL SETUP ──────────────────────────────────────
  const gl = glCanvas.getContext('webgl', { antialias: true, alpha: false })!;

  const VERT_SRC = `
    attribute vec3 aPos;
    uniform mat4 uProj;
    uniform mat4 uView;
    varying vec3 vPos;
    void main() {
      vPos = aPos;
      gl_Position = uProj * uView * vec4(aPos, 1.0);
    }
  `;

  const FRAG_SRC = `
    precision mediump float;
    varying vec3 vPos;
    uniform float uHorizonAlt;
    void main() {
      // Compute altitude of this fragment on the unit sphere
      float alt = asin(clamp(vPos.y, -1.0, 1.0));

      // Sky color: black above horizon, slightly brighter below
      float belowHorizon = smoothstep(0.005, -0.005, alt);
      vec3 skyAbove = vec3(0.02, 0.02, 0.04);
      vec3 skyBelow = vec3(0.06, 0.05, 0.04);
      vec3 col = mix(skyAbove, skyBelow, belowHorizon);

      // Horizon glow line
      float horizonLine = 1.0 - smoothstep(0.0, 0.008, abs(alt));
      col += vec3(1.0, 1.0, 1.0) * horizonLine * 0.12;

      gl_FragColor = vec4(col, 1.0);
    }
  `;

  function compileShader(src: string, type: number): WebGLShader {
    const s = gl.createShader(type)!;
    gl.shaderSource(s, src);
    gl.compileShader(s);
    return s;
  }

  const prog = gl.createProgram()!;
  gl.attachShader(prog, compileShader(VERT_SRC, gl.VERTEX_SHADER));
  gl.attachShader(prog, compileShader(FRAG_SRC, gl.FRAGMENT_SHADER));
  gl.linkProgram(prog);
  gl.useProgram(prog);

  const aPos = gl.getAttribLocation(prog, 'aPos');
  const uProj = gl.getUniformLocation(prog, 'uProj');
  const uView = gl.getUniformLocation(prog, 'uView');

  // Build sphere (inside-out so we see interior)
  function buildSphere(rings: number, segs: number): { verts: Float32Array; indices: Uint16Array } {
    const verts: number[] = [];
    const indices: number[] = [];
    for (let r = 0; r <= rings; r++) {
      const phi = (r / rings) * Math.PI;
      for (let s = 0; s <= segs; s++) {
        const theta = (s / segs) * Math.PI * 2;
        const x = Math.sin(phi) * Math.cos(theta);
        const y = Math.cos(phi);
        const z = Math.sin(phi) * Math.sin(theta);
        verts.push(x, y, z);
      }
    }
    for (let r = 0; r < rings; r++) {
      for (let s = 0; s < segs; s++) {
        const a = r * (segs + 1) + s;
        const b = a + segs + 1;
        // Reversed winding for inside-out
        indices.push(a, a + 1, b);
        indices.push(b, a + 1, b + 1);
      }
    }
    return { verts: new Float32Array(verts), indices: new Uint16Array(indices) };
  }

  const sphere = buildSphere(48, 96);

  const vbo = gl.createBuffer()!;
  gl.bindBuffer(gl.ARRAY_BUFFER, vbo);
  gl.bufferData(gl.ARRAY_BUFFER, sphere.verts, gl.STATIC_DRAW);

  const ibo = gl.createBuffer()!;
  gl.bindBuffer(gl.ELEMENT_ARRAY_BUFFER, ibo);
  gl.bufferData(gl.ELEMENT_ARRAY_BUFFER, sphere.indices, gl.STATIC_DRAW);

  gl.enableVertexAttribArray(aPos);
  gl.vertexAttribPointer(aPos, 3, gl.FLOAT, false, 0, 0);

  // ── MATRIX UTILS ─────────────────────────────────────
  function perspective(fovY: number, aspect: number, near: number, far: number): Float32Array {
    const f = 1 / Math.tan(fovY / 2);
    const nf = 1 / (near - far);
    return new Float32Array([
      f / aspect, 0, 0, 0,
      0, f, 0, 0,
      0, 0, (far + near) * nf, -1,
      0, 0, 2 * far * near * nf, 0,
    ]);
  }

  function lookAt(yaw: number, pitch: number): Float32Array {
    // Camera at origin looking outward based on yaw/pitch
    const cy = Math.cos(yaw), sy = Math.sin(yaw);
    const cp = Math.cos(pitch), sp = Math.sin(pitch);

    // Forward direction
    const fx = sy * cp;
    const fy = sp;
    const fz = -cy * cp;

    // Right = forward × up (0,1,0)
    const rx = cy, ry = 0, rz = sy;

    // Actual up = right × forward
    const ux = ry * fz - rz * fy;
    const uy = rz * fx - rx * fz;
    const uz = rx * fy - ry * fx;

    // View matrix (transpose of rotation, no translation since camera is at origin)
    return new Float32Array([
      rx, ux, -fx, 0,
      ry, uy, -fy, 0,
      rz, uz, -fz, 0,
      0, 0, 0, 1,
    ]);
  }

  // ── STATE ────────────────────────────────────────────
  let W = 0, H = 0;
  let observer: InstanceType<typeof Astronomy.Observer> | null = null;

  // Camera yaw (azimuth in radians) and pitch (altitude in radians)
  let camYaw = Math.PI; // start looking south (az=180)
  let camPitch = 0.5;   // slightly above horizon

  const FOV = 70 * Math.PI / 180;

  // Drag
  let dragging = false;
  let dragStartX = 0, dragStartY = 0;
  let dragStartYaw = 0, dragStartPitch = 0;

  // Bodies
  const PLANETS = ['Mercury', 'Venus', 'Mars', 'Jupiter', 'Saturn', 'Uranus', 'Neptune'] as const;
  const BODIES = ['Sun', 'Moon', ...PLANETS] as const;

  // Approximate order from Sun (used for brightness — lower index = nearer)
  const DISTANCE_ORDER: Record<string, number> = {
    Moon: 0, Sun: 0, Mercury: 1, Venus: 2, Mars: 3,
    Jupiter: 4, Saturn: 5, Uranus: 6, Neptune: 7,
  };

  // Apparent color of each body as a point of light
  const BODY_COLOR: Record<string, string> = {
    Sun: '255, 220, 150',     // warm yellow-white
    Moon: '210, 210, 200',    // pale silver
    Mercury: '180, 175, 165', // dull grey-white
    Venus: '255, 248, 220',   // brilliant white-yellow
    Mars: '220, 120, 80',     // orange-red
    Jupiter: '235, 215, 180', // creamy tan
    Saturn: '230, 210, 160',  // pale gold
    Uranus: '180, 220, 230',  // faint blue-green
    Neptune: '130, 160, 220', // soft blue
  };

  // Visibility toggles: paths only (bodies always shown)
  const pathVisible: Record<string, boolean> = {};
  for (const name of BODIES) {
    pathVisible[name] = false; // all paths off by default
  }

  // Build toggle panel
  function buildTogglePanel() {
    togglePanel.innerHTML = '';
    for (const name of BODIES) {
      if (name === 'Sun') continue;
      const col = BODY_COLOR[name] ?? '255, 255, 255';

      const row = document.createElement('div');
      row.className = 'ce-toggle-row';

      const dot = document.createElement('span');
      dot.className = 'ce-toggle-dot';
      dot.style.background = `rgb(${col})`;

      const label = document.createElement('label');
      label.textContent = name;
      label.style.color = `rgba(${col}, 0.7)`;

      const check = document.createElement('input');
      check.type = 'checkbox';
      check.checked = pathVisible[name];
      check.style.borderColor = `rgba(${col}, 0.3)`;
      check.addEventListener('change', () => { pathVisible[name] = check.checked; render(); });

      label.addEventListener('click', (e) => { e.preventDefault(); check.checked = !check.checked; pathVisible[name] = check.checked; render(); });

      row.appendChild(dot);
      row.appendChild(label);
      row.appendChild(check);
      togglePanel.appendChild(row);
    }

  }

  toggleBtn.addEventListener('click', () => {
    togglePanel.classList.toggle('hidden');
  });

  buildTogglePanel();

  interface TrailPoint { az: number; alt: number; }

  interface BodyData {
    name: string;
    az: number;
    alt: number;
    trail: TrailPoint[];
    isMoon: boolean;
    trailAlpha: number;
    color: string; // r, g, b
  }

  let bodyData: BodyData[] = [];
  let moonPhase = 0;
  let refreshInterval: number | null = null;

  // ── RESIZE ───────────────────────────────────────────
  function resize() {
    const dpr = window.devicePixelRatio || 1;
    W = window.innerWidth;
    H = window.innerHeight;
    glCanvas.width = W * dpr;
    glCanvas.height = H * dpr;
    overlay.width = W * dpr;
    overlay.height = H * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    gl.viewport(0, 0, W * dpr, H * dpr);
    render();
  }

  // ── COMPUTE POSITIONS ────────────────────────────────
  // Orbital periods in days (for sampling one full orbit)
  const ORBITAL_PERIODS: Record<string, number> = {
    Moon: 27.32, Mercury: 87.97, Venus: 224.7, Mars: 687,
    Jupiter: 4333, Saturn: 10759, Uranus: 30687, Neptune: 60190,
  };

  function computePositions() {
    if (!observer) return;

    const now = Astronomy.MakeTime(new Date());
    moonPhase = Astronomy.MoonPhase(now);
    bodyData = [];

    // Earth's current heliocentric position (J2000 equatorial)
    const earthVec = Astronomy.HelioVector('Earth', now);

    for (const name of BODIES) {
      const isMoon = name === 'Moon';
      const isSun = name === 'Sun';

      // Current position
      const eq = Astronomy.Equator(name, now, observer, true, true);
      const hor = Astronomy.Horizon(now, observer, eq.ra, eq.dec, 'normal');

      const trail: TrailPoint[] = [];
      const period = ORBITAL_PERIODS[name] ?? 365;
      const steps = 120;

      if (isSun) {
        // Sun has no orbital trail
      } else if (isMoon) {
        if (isMoon) {
          // Moon trail: use ecliptic but shifted so it passes through the Moon.
          // Sample the Sun's RA/Dec over a year, find the point closest in RA
          // to the Moon, compute the dec offset there, and apply uniformly.
          const moonEq = Astronomy.Equator('Moon', now, observer, true, true);

          // First pass: collect ecliptic points and find closest RA to Moon
          const eclipticPts: { ra: number; dec: number }[] = [];
          for (let i = 0; i <= steps; i++) {
            const offsetDays = (i / steps) * 365.25;
            const t = Astronomy.MakeTime(new Date(Date.now() + offsetDays * 86400000));
            const teq = Astronomy.Equator('Sun', t, observer, true, true);
            eclipticPts.push({ ra: teq.ra, dec: teq.dec });
          }

          // Find ecliptic point with closest RA to Moon
          let closestIdx = 0;
          let closestRaDiff = Infinity;
          for (let i = 0; i < eclipticPts.length; i++) {
            let diff = Math.abs(eclipticPts[i].ra - moonEq.ra);
            if (diff > 12) diff = 24 - diff; // wrap around 24h
            if (diff < closestRaDiff) { closestRaDiff = diff; closestIdx = i; }
          }
          const decOffset = moonEq.dec - eclipticPts[closestIdx].dec;

          for (let i = 0; i < eclipticPts.length; i++) {
            const thor = Astronomy.Horizon(now, observer, eclipticPts[i].ra, eclipticPts[i].dec + decOffset, 'normal');
            trail.push({ az: thor.azimuth, alt: thor.altitude });
          }
        } else {
          // Sun: trace the ecliptic over one year
          for (let i = 0; i <= steps; i++) {
            const offsetDays = (i / steps) * 365.25;
            const t = Astronomy.MakeTime(new Date(Date.now() + offsetDays * 86400000));
            const teq = Astronomy.Equator('Sun', t, observer, true, true);
            const thor = Astronomy.Horizon(now, observer, teq.ra, teq.dec, 'normal');
            trail.push({ az: thor.azimuth, alt: thor.altitude });
          }
        }
      } else {
        // Planets: show the heliocentric orbital ellipse as seen from Earth's current position.
        for (let i = 0; i <= steps; i++) {
          const offsetDays = (i / steps) * period;
          const t = Astronomy.MakeTime(new Date(Date.now() + offsetDays * 86400000));

          const pv = Astronomy.HelioVector(name as Astronomy.Body, t);

          const dx = pv.x - earthVec.x;
          const dy = pv.y - earthVec.y;
          const dz = pv.z - earthVec.z;
          const dist = Math.sqrt(dx * dx + dy * dy + dz * dz);

          let ra = Math.atan2(dy, dx) * 12 / Math.PI;
          if (ra < 0) ra += 24;
          const dec = Math.asin(dz / dist) * 180 / Math.PI;

          const thor = Astronomy.Horizon(now, observer, ra, dec, 'normal');
          trail.push({ az: thor.azimuth, alt: thor.altitude });
        }
      }

      // Trail brightness: nearer bodies are brighter
      const distIdx = DISTANCE_ORDER[name] ?? 4;
      const trailAlpha = 0.35 - distIdx * 0.035; // Moon=0.35, Neptune=0.07

      const color = BODY_COLOR[name] ?? '255, 255, 255';
      bodyData.push({ name, az: hor.azimuth, alt: hor.altitude, trail, isMoon, trailAlpha, color });
    }
  }

  // ── PROJECTION (az/alt → screen) ────────────────────
  // Convert az/alt to a 3D point on the unit sphere, then project with camera
  function azAltToVec3(azDeg: number, altDeg: number): [number, number, number] {
    const az = azDeg * Math.PI / 180;
    const alt = altDeg * Math.PI / 180;
    // Astronomy convention: az=0 is north, increases clockwise
    // Our GL: yaw=0 faces -Z, yaw increases counterclockwise
    // Map: GL_x = sin(az), GL_y = sin(alt), GL_z = -cos(az)*cos(alt)
    const ca = Math.cos(alt);
    return [
      Math.sin(az) * ca,
      Math.sin(alt),
      -Math.cos(az) * ca,
    ];
  }

  function projectToScreen(azDeg: number, altDeg: number): { x: number; y: number; visible: boolean } {
    const [wx, wy, wz] = azAltToVec3(azDeg, altDeg);

    // Apply view matrix
    const viewMat = lookAt(camYaw, camPitch);
    const vx = viewMat[0] * wx + viewMat[4] * wy + viewMat[8] * wz;
    const vy = viewMat[1] * wx + viewMat[5] * wy + viewMat[9] * wz;
    const vz = viewMat[2] * wx + viewMat[6] * wy + viewMat[10] * wz;

    // Behind camera?
    if (vz >= 0) return { x: -9999, y: -9999, visible: false };

    // Perspective projection
    const aspect = W / H;
    const f = 1 / Math.tan(FOV / 2);
    const sx = (vx * f / aspect) / (-vz);
    const sy = (vy * f) / (-vz);

    // NDC → screen
    const x = (sx * 0.5 + 0.5) * W;
    const y = (0.5 - sy * 0.5) * H;

    const margin = 80;
    const visible = x > -margin && x < W + margin && y > -margin && y < H + margin;

    return { x, y, visible };
  }

  // ── RENDER ───────────────────────────────────────────
  function render() {
    renderGL();
    renderOverlay();
    updateDirection();
  }

  function renderGL() {
    gl.clearColor(0.02, 0.02, 0.04, 1);
    gl.clear(gl.COLOR_BUFFER_BIT | gl.DEPTH_BUFFER_BIT);
    gl.enable(gl.DEPTH_TEST);
    gl.disable(gl.CULL_FACE);

    gl.useProgram(prog);

    const aspect = W / H;
    gl.uniformMatrix4fv(uProj, false, perspective(FOV, aspect, 0.01, 10));
    gl.uniformMatrix4fv(uView, false, lookAt(camYaw, camPitch));

    gl.bindBuffer(gl.ARRAY_BUFFER, vbo);
    gl.bindBuffer(gl.ELEMENT_ARRAY_BUFFER, ibo);
    gl.vertexAttribPointer(aPos, 3, gl.FLOAT, false, 0, 0);

    gl.drawElements(gl.TRIANGLES, sphere.indices.length, gl.UNSIGNED_SHORT, 0);
  }

  function renderOverlay() {
    ctx.clearRect(0, 0, W, H);

    if (!observer) {
      ctx.fillStyle = 'rgba(255, 255, 255, 0.15)';
      ctx.font = '200 1.25rem Outfit, system-ui, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('Enter your location below', W / 2, H / 2);
      return;
    }

    // Draw cardinal labels along horizon
    drawCardinals();

    // Draw trails (toggled) then bodies (always shown)
    for (const bd of bodyData) {
      if (pathVisible[bd.name]) drawTrail(bd);
    }
    for (const bd of bodyData) drawBody(bd);
  }

  function drawCardinals() {
    const cardinals = [
      { az: 0, label: 'N' }, { az: 45, label: 'NE' },
      { az: 90, label: 'E' }, { az: 135, label: 'SE' },
      { az: 180, label: 'S' }, { az: 225, label: 'SW' },
      { az: 270, label: 'W' }, { az: 315, label: 'NW' },
    ];
    ctx.font = '200 0.75rem Outfit, system-ui, sans-serif';
    ctx.textAlign = 'center';

    for (const c of cardinals) {
      const p = projectToScreen(c.az, 0);
      if (!p.visible) continue;
      const edgeDist = Math.min(p.x, W - p.x, p.y, H - p.y);
      const alpha = Math.min(1, Math.max(0, (edgeDist - 10) / 60)) * 0.3;
      if (alpha < 0.01) continue;
      ctx.fillStyle = `rgba(255, 255, 255, ${alpha})`;
      ctx.fillText(c.label, p.x, p.y + 4);
    }
  }

  function drawTrail(bd: BodyData) {
    const trail = bd.trail;
    if (trail.length < 2) return;

    const chevronHalfW = 4;
    const chevronDepth = 6;
    const chevronSpacing = 1.2;
    const strokeW = 1.5;
    const alpha = bd.trailAlpha;

    // Pre-compute cumulative angular distance along the trail (in degrees).
    // This anchors chevron placement to the trail geometry so they don't
    // shift when panning the view.
    const cumDist: number[] = [0];
    for (let i = 1; i < trail.length; i++) {
      let dAz = trail[i].az - trail[i - 1].az;
      if (dAz > 180) dAz -= 360;
      if (dAz < -180) dAz += 360;
      const dAlt = trail[i].alt - trail[i - 1].alt;
      const angDist = Math.sqrt(dAz * dAz + dAlt * dAlt);
      cumDist.push(cumDist[i - 1] + angDist);
    }

    // Scale: convert angular distance to a stable pixel-like spacing
    const totalAng = cumDist[cumDist.length - 1];
    if (totalAng < 0.01) return;

    // Project all points
    const projected: { x: number; y: number; visible: boolean }[] = [];
    for (let i = 0; i < trail.length; i++) {
      projected.push(projectToScreen(trail[i].az, trail[i].alt));
    }

    // Walk segments and place chevrons at fixed angular intervals
    for (let i = 1; i < projected.length; i++) {
      const p0 = projected[i - 1];
      const p1 = projected[i];

      const dx = p1.x - p0.x;
      const dy = p1.y - p0.y;
      const segLen = Math.hypot(dx, dy);

      if (segLen > 300 || segLen < 0.5) continue;
      if (!p0.visible && !p1.visible) continue;

      const nx = dx / segLen;
      const ny = dy / segLen;
      const px = -ny;
      const py = nx;

      const angStart = cumDist[i - 1];
      const angEnd = cumDist[i];
      const angLen = angEnd - angStart;
      if (angLen < 0.001) continue;

      // Find first chevron in this segment
      const firstChevIdx = Math.ceil(angStart / chevronSpacing);
      const lastChevIdx = Math.floor(angEnd / chevronSpacing);

      for (let ci = firstChevIdx; ci <= lastChevIdx; ci++) {
        const angPos = ci * chevronSpacing;
        const frac = (angPos - angStart) / angLen;

        const tipX = p0.x + dx * frac;
        const tipY = p0.y + dy * frac;

        if (tipX > -20 && tipX < W + 20 && tipY > -20 && tipY < H + 20) {
          const backX = tipX - nx * chevronDepth;
          const backY = tipY - ny * chevronDepth;

          ctx.beginPath();
          ctx.moveTo(backX + px * chevronHalfW, backY + py * chevronHalfW);
          ctx.lineTo(tipX, tipY);
          ctx.lineTo(backX - px * chevronHalfW, backY - py * chevronHalfW);
          ctx.strokeStyle = `rgba(${bd.color}, ${alpha})`;
          ctx.lineWidth = strokeW;
          ctx.lineJoin = 'round';
          ctx.lineCap = 'round';
          ctx.stroke();
        }
      }
    }
  }

  // Apparent angular diameter in degrees → pixel radius
  function angularToPixels(degrees: number): number {
    const f = 1 / Math.tan(FOV / 2);
    return (degrees / 2) * (Math.PI / 180) * f * (H / 2);
  }

  function drawBody(bd: BodyData) {
    const p = projectToScreen(bd.az, bd.alt);
    if (!p.visible) return;

    const col = BODY_COLOR[bd.name] ?? '255, 255, 255';

    const isSun = bd.name === 'Sun';
    const isMoonBody = bd.name === 'Moon';
    const sunMoonR = Math.max(8, angularToPixels(0.53));
    let r: number;
    if (isSun || isMoonBody) {
      r = sunMoonR;
    } else {
      r = Math.max(3, sunMoonR / 4);
    }

    if (isMoonBody) {
      drawMoon(p.x, p.y, r, col);
    } else {
      ctx.beginPath();
      ctx.arc(p.x, p.y, r, 0, Math.PI * 2);
      ctx.fillStyle = '#000';
      ctx.fill();
      ctx.strokeStyle = `rgba(${col}, 0.3)`;
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // Label fades in away from edges
    const edgeDist = Math.min(p.x, W - p.x, p.y, H - p.y);
    const labelAlpha = Math.min(1, Math.max(0, (edgeDist - 30) / 80));

    if (labelAlpha > 0.01) {
      ctx.font = '200 0.75rem Outfit, system-ui, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillStyle = `rgba(${col}, ${labelAlpha * 0.7})`;
      ctx.fillText(bd.name, p.x, p.y - r - 8);
    }
  }

  function drawMoon(x: number, y: number, r: number, col: string) {
    // Dark base
    ctx.beginPath();
    ctx.arc(x, y, r, 0, Math.PI * 2);
    ctx.fillStyle = '#000';
    ctx.fill();
    ctx.strokeStyle = `rgba(${col}, 0.3)`;
    ctx.lineWidth = 1;
    ctx.stroke();

    // Lit portion
    ctx.save();
    ctx.beginPath();
    ctx.arc(x, y, r, 0, Math.PI * 2);
    ctx.clip();

    const phase = moonPhase;
    const phaseRad = (phase * Math.PI) / 180;

    ctx.beginPath();
    if (phase <= 180) {
      ctx.arc(x, y, r, -Math.PI / 2, Math.PI / 2, false);
      const tx = Math.cos(phaseRad) * r;
      ctx.ellipse(x, y, Math.abs(tx), r, 0, Math.PI / 2, -Math.PI / 2, phase < 90);
    } else {
      ctx.arc(x, y, r, Math.PI / 2, -Math.PI / 2, false);
      const tx = Math.cos(phaseRad) * r;
      ctx.ellipse(x, y, Math.abs(tx), r, 0, -Math.PI / 2, Math.PI / 2, phase > 270);
    }
    ctx.closePath();
    ctx.fillStyle = `rgba(${col}, 0.9)`;
    ctx.fill();
    ctx.restore();
  }

  function updateDirection() {
    let azDeg = (camYaw * 180 / Math.PI);
    azDeg = ((azDeg % 360) + 360) % 360;
    const altDeg = camPitch * 180 / Math.PI;
    const dirs = ['N', 'NE', 'E', 'SE', 'S', 'SW', 'W', 'NW'];
    const idx = Math.round(azDeg / 45) % 8;
    const altLabel = altDeg > 5 ? ` +${Math.round(altDeg)}°` : altDeg < -5 ? ` ${Math.round(altDeg)}°` : '';
    directionEl.textContent = `${dirs[idx]} ${Math.round(azDeg)}°${altLabel}`;
  }

  // ── DRAG ─────────────────────────────────────────────
  function onPointerDown(clientX: number, clientY: number) {
    dragging = true;
    dragStartX = clientX;
    dragStartY = clientY;
    dragStartYaw = camYaw;
    dragStartPitch = camPitch;
  }

  function onPointerMove(clientX: number, clientY: number) {
    if (!dragging) return;
    const dx = clientX - dragStartX;
    const dy = clientY - dragStartY;

    // Radians per pixel — tied to FOV so drag feels natural
    const radPerPx = FOV / H;
    camYaw = dragStartYaw - dx * radPerPx;
    camPitch = Math.max(-Math.PI / 2, Math.min(Math.PI / 2, dragStartPitch + dy * radPerPx));

    render();
  }

  function onPointerUp() {
    dragging = false;
  }

  glCanvas.addEventListener('mousedown', (e) => { e.preventDefault(); onPointerDown(e.clientX, e.clientY); });
  window.addEventListener('mousemove', (e) => onPointerMove(e.clientX, e.clientY));
  window.addEventListener('mouseup', onPointerUp);

  glCanvas.addEventListener('touchstart', (e) => { e.preventDefault(); onPointerDown(e.touches[0].clientX, e.touches[0].clientY); }, { passive: false });
  glCanvas.addEventListener('touchmove', (e) => { e.preventDefault(); onPointerMove(e.touches[0].clientX, e.touches[0].clientY); }, { passive: false });
  glCanvas.addEventListener('touchend', onPointerUp);

  // ── GEOCODING ────────────────────────────────────────
  async function geocode(query: string): Promise<{ lat: number; lon: number; display: string } | null> {
    const url = `https://nominatim.openstreetmap.org/search?format=json&limit=1&q=${encodeURIComponent(query)}`;
    try {
      const res = await fetch(url, { headers: { 'User-Agent': 'centeric-experiment/1.0' } });
      const data = await res.json();
      if (data.length === 0) return null;
      return { lat: parseFloat(data[0].lat), lon: parseFloat(data[0].lon), display: data[0].display_name };
    } catch { return null; }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const query = input.value.trim();
    if (!query) return;

    let dotCount = 0;
    const dotInterval = setInterval(() => {
      dotCount = (dotCount % 3) + 1;
      statusEl.textContent = 'Finding your location' + '.'.repeat(dotCount);
    }, 400);
    statusEl.textContent = 'Finding your location.';

    const result = await geocode(query);
    clearInterval(dotInterval);
    if (!result) { statusEl.textContent = 'Location not found. Try again.'; return; }

    observer = new Astronomy.Observer(result.lat, result.lon, 0);
    statusEl.textContent = result.display.split(',').slice(0, 3).join(',');

    computePositions();
    render();

    if (refreshInterval) clearInterval(refreshInterval);
    refreshInterval = window.setInterval(() => { computePositions(); render(); }, 60000);
  });

  // ── INIT ─────────────────────────────────────────────
  window.addEventListener('resize', resize);
  resize();
</script>
