---
/*
 * Footer: Appears at the bottom of every page via the layout.
 *
 * new Date().getFullYear() runs at BUILD TIME in Astro (not in the browser).
 * This means the year updates whenever you rebuild the site — no JavaScript
 * is sent to the visitor's browser for this.
 */
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <p>&copy; {year} Mike Harris</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0;
    margin-top: var(--space-xl);
    color: var(--color-muted);
    font-size: 0.875rem;
    text-align: center;
  }
</style>
