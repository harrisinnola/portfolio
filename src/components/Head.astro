---
/*
 * Head Component: Renders the <head> section for every page.
 *
 * Props:
 *   title — the page name (appears in the browser tab)
 *   description — a short summary for search engines
 *
 * Each page passes its own title and description, so every page
 * has unique SEO metadata. Search engines use these to display
 * your site in search results.
 */

import { ViewTransitions } from 'astro:transitions';

const { title, description } = Astro.props;

// Build a consistent format: "Page Name | Mike Harris"
const fullTitle = title === 'Home'
  ? 'Mike Harris'
  : `${title} | Mike Harris`;
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;200;300;400&display=swap" rel="stylesheet" />
  <ViewTransitions />
</head>
