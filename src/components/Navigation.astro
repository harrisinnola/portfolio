---
const currentPath = Astro.url.pathname;

const links = [
  { label: 'Ideas', href: '/experiments/' },
  { label: 'Past Work', href: '/prototypes/' },
  { label: 'Contact', href: '/contact/' },
];
---

<header class="site-header">
  <nav aria-label="Main">
    <ul>
      {links.map(link => (
        <li>
          <a
            href={link.href}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .site-header {
    padding: var(--space-md) 0;
  }

  nav {
    display: flex;
    justify-content: center;
  }

  ul {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-md);
    list-style: none;
    padding: 0;
  }

  li:first-child {
    text-align: right;
  }

  li:last-child {
    text-align: left;
  }


  a {
    color: var(--color-muted);
    text-decoration: none;
    padding: var(--space-xs) var(--space-sm);
    font-size: 0.9375rem;
    font-weight: 200;
    letter-spacing: 0.08em;
    transition: color 0.15s;
  }

  a:hover {
    color: var(--color-text);
  }

  a[aria-current='page'] {
    color: var(--color-text);
    font-weight: 300;
  }
</style>
